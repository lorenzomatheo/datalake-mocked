{
    "id": "PHOTO_PICKER",
    "title": "Photo Picker Example",
    "terminal": true,
    "data": {},
    "layout": {
        "type": "SingleColumnLayout",
        "children": [
            {
                "type": "Form",
                "name": "flow_path",
                "children": [
                    {
                        "type": "Image",
                        "src": "",
                        "height": 80
                    },
                    {
                        "type": "PhotoPicker",
                        "name": "photo_picker",
                        "label": "Envie as fotos do balcão",
                        "description": "Por favor, clique em tirar foto e envie.",
                        "photo-source": "camera_gallery",
                        "min-uploaded-photos": 1,
                        "max-uploaded-photos": 5,
                        "max-file-size-kb": 20480
                    },
                    {
                        "type": "Footer",
                        "label": "Enviar fotos",
                        "on-click-action": {
                            "name": "data_exchange",
                            "payload": {
                                "images": "${form.photo_picker}"
                            }
                        }
                    }
                ]
            }
        ]
    }
        }